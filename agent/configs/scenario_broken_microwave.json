{
  "scenario_name": "Broken Microwave Fallback",
  "environment_id": 2,
  "init_rooms": ["kitchen"],
  "goal_instruction": "如果看到牛奶，帮我加热它。",
  "max_steps": 30,
  "sabotage": {
    "target_class": "microwave",
    "remove_properties": ["HAS_SWITCH", "HAS_PLUG"]
  },
  "initial_states_override": [
    {
      "target_classes": ["toaster", "coffe_maker", "stove", "oven"],
      "remove_states": ["PLUGGED_IN", "ON"],
      "add_states": ["PLUGGED_OUT", "OFF"]
    }
  ],
  "success_condition": {
    "target_class": "milk",
    "require_state": "HOT",
    "quantifier": "any"
  }
}
